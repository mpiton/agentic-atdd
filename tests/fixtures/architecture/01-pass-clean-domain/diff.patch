@@ -0,0 +1,16 @@
+import type { Cart, Customer, SubmissionResult } from "../domain/types";
+import type { PaymentGateway } from "../ports/payment-gateway";
+
+export function submitCart(
+  { customer, cart }: { customer: Customer; cart: Cart },
+  deps: { paymentGateway: PaymentGateway },
+): Promise<SubmissionResult> {
+  if (cart.lines.length === 0) {
+    return Promise.resolve({ status: "rejected", reason: "EMPTY_CART" });
+  }
+  return deps.paymentGateway.authorize(cart.totalEUR).then((auth) =>
+    auth.ok
+      ? { status: "accepted", orderId: auth.orderId, total: cart.totalEUR }
+      : { status: "rejected", reason: "PAYMENT_DECLINED" },
+  );
+}
