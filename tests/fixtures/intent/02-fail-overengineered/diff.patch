--- /dev/null
+++ b/src/checkout/submit-cart.ts
@@ -0,0 +1,40 @@
+import type { Cart, Customer, SubmissionResult } from "../domain/types";
+import { logger } from "../infra/logger";
+import { metrics } from "../infra/metrics";
+import { featureFlags } from "../infra/feature-flags";
+
+const submissionCache = new Map<string, SubmissionResult>();
+
+export async function submitCart(
+  { customer, cart, idempotencyKey, retryCount = 0 }: {
+    customer: Customer;
+    cart: Cart;
+    idempotencyKey?: string;
+    retryCount?: number;
+  },
+): Promise<SubmissionResult> {
+  metrics.increment("checkout.submit.attempt");
+
+  if (idempotencyKey && submissionCache.has(idempotencyKey)) {
+    logger.info("returning cached submission", { idempotencyKey });
+    return submissionCache.get(idempotencyKey)!;
+  }
+
+  if (!featureFlags.isEnabled("checkout.v2", customer.id)) {
+    logger.warn("checkout.v2 disabled, falling back silently");
+    return { status: "accepted" };
+  }
+
+  if (cart.lines.length === 0) {
+    const result: SubmissionResult = { status: "rejected", reason: "EMPTY_CART" };
+    if (idempotencyKey) submissionCache.set(idempotencyKey, result);
+    return result;
+  }
+
+  const result: SubmissionResult = { status: "accepted" };
+  if (idempotencyKey) submissionCache.set(idempotencyKey, result);
+
+  if (retryCount > 3) throw new Error("too many retries");
+
+  return result;
+}
