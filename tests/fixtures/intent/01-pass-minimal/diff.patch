+import type { Cart, Customer, SubmissionResult } from "../domain/types";
+
+export function submitCart(
+  { cart }: { customer: Customer; cart: Cart },
+): SubmissionResult {
+  return cart.lines.length === 0 ? { status: "rejected", reason: "EMPTY_CART" } : { status: "accepted" };
+}
