{
  "$schema": "https://anthropic.com/claude-code/plugin.schema.json",
  "name": "atdd-pipeline",
  "version": "0.1.0",
  "description": "Multi-agent ATDD pipeline for Claude Code and Codex. Impact map -> Gherkin -> GitHub Issues -> RED/GREEN with parallel reviewers and autonomous sub-PR merging. Two human gates: spec, and the final PR.",
  "author": {
    "name": "Mathieu Piton",
    "email": "matpiton@protonmail.com",
    "url": "https://github.com/mpiton"
  },
  "homepage": "https://github.com/mpiton/agentic-atdd",
  "repository": "https://github.com/mpiton/agentic-atdd",
  "license": "MIT",
  "keywords": [
    "atdd",
    "tdd",
    "acceptance-testing",
    "gherkin",
    "multi-agent",
    "claude-code",
    "codex-cli",
    "workflow",
    "skills",
    "agentic",
    "ai-pairing",
    "llm-tools"
  ],
  "category": "workflow",
  "skills": [
    { "name": "impact-map",          "path": "skills/spec/impact-map/SKILL.md" },
    { "name": "from-issue",          "path": "skills/spec/from-issue/SKILL.md" },
