    { "name": "red-cycle",           "path": "skills/execute/red-cycle/SKILL.md" },
    { "name": "green-cycle",         "path": "skills/execute/green-cycle/SKILL.md" },
    { "name": "review-fidelity",     "path": "skills/execute/review-fidelity/SKILL.md" },
    { "name": "review-architecture", "path": "skills/execute/review-architecture/SKILL.md" },
    { "name": "review-intent",       "path": "skills/execute/review-intent/SKILL.md" },
    { "name": "apply-pr-feedback",   "path": "skills/execute/apply-pr-feedback/SKILL.md" },
    { "name": "pr-auto-merge",       "path": "skills/execute/pr-auto-merge/SKILL.md" },
    { "name": "atdd-run",            "path": "skills/orchestrate/atdd-run/SKILL.md" },
    { "name": "setup-atdd-pipeline", "path": "skills/orchestrate/setup-atdd-pipeline/SKILL.md" }
