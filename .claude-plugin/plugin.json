    { "name": "spec-review",         "skill": "spec-review" },
    { "name": "to-issues-atdd",      "skill": "to-issues-atdd" },
    { "name": "red",                 "skill": "red-cycle" },
    { "name": "green",               "skill": "green-cycle" },
    { "name": "atdd-run",            "skill": "atdd-run" },
    { "name": "review-fidelity",     "skill": "review-fidelity" },
    { "name": "review-architecture", "skill": "review-architecture" },
    { "name": "review-intent",       "skill": "review-intent" },
